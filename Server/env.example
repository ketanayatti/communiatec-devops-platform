# Communiatec Server Environment Variables
# Copy this to .env and update with your actual values

# Database
DATABASE_URL=mongodb://admin:communiatec_secure_password@localhost:27017/communiatec_chat
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database

# Security
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
ENCRYPTION_KEY=your_encryption_key_32_chars

# Server Config
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
# Comma-separated list of allowed origins for CORS. Include local and production frontends.
# Example for production:
# CORS_ALLOWED_ORIGINS=https://communiatec.vercel.app,https://communiatec.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# If you want to allow Vercel preview urls (e.g. https://<hash>-communiatec.vercel.app)
# set this to true. Leave true by default.
ALLOW_VERCEL_PREVIEWS=true

# Redis (use 'disabled' for development)
REDIS_URL=disabled

# External Services
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# OAuth
GITHUB_CLIENT_ID=your_github_id
GITHUB_CLIENT_SECRET=your_github_secret
LINKEDIN_CLIENT_ID=your_linkedin_id
LINKEDIN_CLIENT_SECRET=your_linkedin_secret

# Server public URL (used for OAuth callbacks and keepalive in production)
# SERVER_URL=https://communiatec.onrender.com

# AI Services
GEMINI_API_KEY=your_gemini_key
JUDGE0_API_KEY=your_judge0_key
